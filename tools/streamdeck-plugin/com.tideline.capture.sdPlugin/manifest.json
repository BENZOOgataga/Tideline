{
  "Name": "Tideline",
  "Version": "1.1.0.0",
  "Author": "BENZOOgataga",
  "URL": "https://github.com/BENZOOgataga/Tideline",
  "Description": "Open the Tideline capture overlay from a Stream Deck button.",
  "Icon": "imgs/tidelineIcon",
  "Category": "Tideline",
  "CategoryIcon": "imgs/tidelineIcon",
  "CodePath": "bin/plugin.js",
  "PropertyInspectorPath": "ui/inspector.html",
  "DefaultWindowSize": [500, 280],
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "UUID": "com.tideline.capture",
  "Actions": [
    {
      "Name": "Capture to Tideline",
      "UUID": "com.tideline.capture.action",
      "Icon": "imgs/tidelineIcon",
      "Tooltip": "Open the Tideline capture overlay.",
      "PropertyInspectorPath": "ui/inspector.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/tidelineIcon",
          "TitleAlignment": "middle",
          "FontSize": "12"
        }
      ]
    }
  ]
}
