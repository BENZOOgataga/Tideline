<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tideline.App.Views.ListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tideline.App.ViewModels">
    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="The List" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock x:Name="SubtitleText"
                       Text="One prioritised note stream."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Opacity="0.7" />
        </StackPanel>

        <AutoSuggestBox x:Name="SearchBox"
                        Grid.Row="1"
                        PlaceholderText="Search notes"
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged"
                        QuerySubmitted="SearchBox_QuerySubmitted" />

        <ScrollViewer Grid.Row="2" VerticalScrollMode="Auto">
            <ListView x:Name="NotesList"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="NotesList_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:NoteCard">
                        <Grid Padding="0,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{x:Bind Body}"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{x:Bind Framing}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.6" />
                                    <TextBlock Text="{x:Bind DueText}"
                                               Visibility="{x:Bind HasDue}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.6" />
                                    <TextBlock Text="{x:Bind RemindText}"
                                               Visibility="{x:Bind HasRemind}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.6" />
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Click="ArchiveButton_Click"
                                    DataContext="{x:Bind}"
                                    Style="{ThemeResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Archive">
                                <FontIcon Glyph="&#xE74D;" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>
