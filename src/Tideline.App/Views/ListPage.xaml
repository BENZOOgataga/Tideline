<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tideline.App.Views.ListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tideline.App.ViewModels">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Modifiers="Control" Key="F" Invoked="FocusSearch_Invoked" />
    </Page.KeyboardAccelerators>

    <Page.Resources>
        <Style x:Key="NoteListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Page.Resources>

    <Grid RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="The List" Style="{ThemeResource TitleLargeTextBlockStyle}" />
            <TextBlock x:Name="SubtitleText"
                       Text="One prioritised note stream."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Opacity="0.6" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox x:Name="SearchBox"
                            Grid.Column="0"
                            PlaceholderText="Filter: #work due:thisweek any:#idea,#someday space:learning"
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged"
                            QuerySubmitted="SearchBox_QuerySubmitted" />
            <Button x:Name="SaveViewButton"
                    Grid.Column="1"
                    Content="Save view"
                    Click="SaveViewButton_Click" />
        </Grid>

        <ListView x:Name="NotesList"
                  Grid.Row="2"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemContainerStyle="{StaticResource NoteListViewItemStyle}"
                  ItemClick="NotesList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:NoteCard">
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <FontIcon Grid.Column="0"
                                      Glyph="&#xE840;"
                                      FontSize="14"
                                      VerticalAlignment="Top"
                                      Margin="0,4,0,0"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                      Visibility="{x:Bind PinnedVisibility}" />

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="{x:Bind Body}"
                                           TextWrapping="Wrap"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           FontSize="14" />
                                <ItemsControl x:Name="ChipsHost">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="6,2">
                                        <TextBlock Text="{x:Bind Framing}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Opacity="0.75" />
                                    </Border>
                                    <Border Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Visibility="{x:Bind DueVisibility}">
                                        <TextBlock Text="{x:Bind DueText}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    </Border>
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Visibility="{x:Bind RemindVisibility}">
                                        <TextBlock Text="{x:Bind RemindText}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Opacity="0.75" />
                                    </Border>
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Visibility="{x:Bind ChecklistVisibility}">
                                        <TextBlock Text="{x:Bind ChecklistText}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Opacity="0.75" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Click="ArchiveButton_Click"
                                    ToolTipService.ToolTip="Archive"
                                    VerticalAlignment="Top">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
