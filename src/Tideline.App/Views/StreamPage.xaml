<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tideline.App.Views.StreamPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Stream" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="Every note, newest at the bottom." Style="{ThemeResource BodyTextBlockStyle}" Opacity="0.7" />
        </StackPanel>
        <Border Grid.Row="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <TextBlock Text="The chronological feed will live here."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Opacity="0.65" />
        </Border>
    </Grid>
</Page>
