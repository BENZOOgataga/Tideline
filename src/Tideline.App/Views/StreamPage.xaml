<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tideline.App.Views.StreamPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tideline.App.ViewModels">

    <Page.Resources>
        <Style x:Key="StreamItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Page.Resources>

    <Grid RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Stream" Style="{ThemeResource TitleLargeTextBlockStyle}" />
            <TextBlock Text="Every note, newest at the bottom."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Opacity="0.6" />
        </StackPanel>

        <AutoSuggestBox x:Name="SearchBox"
                        Grid.Row="1"
                        PlaceholderText="Search the stream"
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged"
                        QuerySubmitted="SearchBox_QuerySubmitted" />

        <ListView x:Name="StreamItems"
                  Grid.Row="2"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  ItemContainerStyle="{StaticResource StreamItemContainerStyle}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:NoteCard">
                    <Border Padding="14,10"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            MaxWidth="720"
                            HorizontalAlignment="Left">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Bind Body}" TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind Framing}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.55" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
