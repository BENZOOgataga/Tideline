<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Tideline.App.Views.NoteEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit note"
    PrimaryButtonText="Save"
    SecondaryButtonText="Archive"
    CloseButtonText="Cancel"
    DefaultButton="Primary">
    <ScrollViewer MaxHeight="520">
        <StackPanel Spacing="14" MinWidth="520" Padding="0,4,0,0">
            <TextBox x:Name="BodyBox"
                     AcceptsReturn="True"
                     MinHeight="120"
                     TextWrapping="Wrap"
                     PlaceholderText="Note body" />

            <TextBlock x:Name="FramingText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.65" />

            <Expander Header="Reminder" HorizontalAlignment="Stretch">
                <StackPanel Spacing="10">
                    <CheckBox x:Name="RemindEnabled" Content="Set a reminder" Checked="RemindEnabled_Toggled" Unchecked="RemindEnabled_Toggled" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="RemindDate" Grid.Column="0" />
                        <TimePicker x:Name="RemindTime" Grid.Column="1" ClockIdentifier="24HourClock" />
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Header="Due date" HorizontalAlignment="Stretch">
                <StackPanel Spacing="10">
                    <CheckBox x:Name="DueEnabled" Content="Set a due date" Checked="DueEnabled_Toggled" Unchecked="DueEnabled_Toggled" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="DueDate" Grid.Column="0" />
                        <TimePicker x:Name="DueTime" Grid.Column="1" ClockIdentifier="24HourClock" />
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Header="Snooze">
                <StackPanel Spacing="8">
                    <TextBlock Text="Push the reminder out."
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="+1 hour" Click="SnoozeOneHour_Click" />
                        <Button Content="Tonight" Click="SnoozeTonight_Click" />
                        <Button Content="Tomorrow" Click="SnoozeTomorrow_Click" />
                        <Button Content="Next week" Click="SnoozeNextWeek_Click" />
                    </StackPanel>
                    <TextBlock x:Name="SnoozeStatus"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.6" />
                </StackPanel>
            </Expander>

            <Expander Header="Recurrence (advanced)">
                <StackPanel Spacing="6">
                    <TextBlock Text="RRULE-style string, e.g. FREQ=WEEKLY;BYDAY=MO"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.6" />
                    <TextBox x:Name="RecurrenceBox" PlaceholderText="Recurrence rule" />
                </StackPanel>
            </Expander>

            <StackPanel Spacing="6">
                <TextBlock Text="Space" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ComboBox x:Name="SpaceCombo" HorizontalAlignment="Stretch" PlaceholderText="Inbox" />
            </StackPanel>

            <Expander Header="Attachments">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add file" Click="AddFile_Click" />
                        <Button Content="Add folder" Click="AddFolder_Click" />
                        <Button Content="Add URL" Click="AddUrl_Click" />
                    </StackPanel>
                    <ItemsControl x:Name="AttachmentsList" />
                    <TextBlock x:Name="AttachmentsHint"
                               Text="Attachments are stored as references (paths or URLs), not copies."
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.55" />
                </StackPanel>
            </Expander>

            <StackPanel Spacing="6">
                <TextBlock Text="Tags" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="TagsBox"
                         PlaceholderText="space-separated, e.g. work urgent idea" />
            </StackPanel>

            <ToggleSwitch x:Name="PinnedToggle" Header="Pinned" OffContent="Off" OnContent="On" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
