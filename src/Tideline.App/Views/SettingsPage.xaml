<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tideline.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="Configure capture, briefing, theme, and updates."
                           Style="{ThemeResource BodyTextBlockStyle}" Opacity="0.7" />
            </StackPanel>
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Theme" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <RadioButtons x:Name="ThemeChoice" SelectionChanged="ThemeChoice_SelectionChanged">
                        <x:String>System</x:String>
                        <x:String>Light</x:String>
                        <x:String>Dark</x:String>
                    </RadioButtons>
                    <TextBlock Text="System follows Windows light or dark mode."
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.55"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Capture hotkey" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="Ctrl + Alt + N" Style="{ThemeResource BodyTextBlockStyle}" />
                    <InfoBar x:Name="HotkeyWarning"
                             IsOpen="False"
                             Severity="Warning"
                             Title="Hotkey not registered"
                             IsClosable="False" />
                </StackPanel>
            </Border>
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Database location" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="DbPathText"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.75"
                               IsTextSelectionEnabled="True" />
                </StackPanel>
            </Border>
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Auto-start" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <ToggleSwitch x:Name="AutoStartToggle"
                                  Header="Launch Tideline on user logon"
                                  OffContent="Off"
                                  OnContent="On"
                                  Toggled="AutoStartToggle_Toggled" />
                    <TextBlock Text="Uses Task Scheduler with an 8-second delay so the app does not compete for boot resources."
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.6"
                               TextWrapping="Wrap" />
                    <InfoBar x:Name="AutoStartWarning" IsOpen="False" Severity="Warning" IsClosable="False" />
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Privacy" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Opacity="0.8"
                               Text="Tideline is local-first. No telemetry, no accounts, no cloud sync. Archived notes are permanently deleted 90 days after they were archived, never pinned notes, and only on app launch." />
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="About" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                    <Grid ColumnSpacing="16" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App"        Opacity="0.6" />
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AppNameText"      IsTextSelectionEnabled="True" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Version"    Opacity="0.6" />
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="VersionText"      IsTextSelectionEnabled="True" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Build"      Opacity="0.6" />
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BuildText"        IsTextSelectionEnabled="True" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Install"    Opacity="0.6" />
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InstallText"      IsTextSelectionEnabled="True" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Updates"    Opacity="0.6" />
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="UpdateStatusText" IsTextSelectionEnabled="True" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="CheckUpdatesButton"
                                Content="Check for updates"
                                Click="CheckUpdates_Click" />
                        <Button x:Name="OpenReleasesButton"
                                Content="Open releases page"
                                Click="OpenReleases_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
