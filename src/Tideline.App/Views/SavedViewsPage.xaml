<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tideline.App.Views.SavedViewsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Saved views" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="Filters you saved from The List."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Opacity="0.7" />
        </StackPanel>
        <ScrollViewer Grid.Row="1">
            <ListView x:Name="ViewsList" SelectionMode="None" />
        </ScrollViewer>
    </Grid>
</Page>
