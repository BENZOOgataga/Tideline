<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Tideline.App.Views.CaptureWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:Microsoft.UI.Xaml.Media">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Border Background="Transparent" Padding="22,18">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0"
                          Glyph="&#xE104;"
                          FontSize="18"
                          Opacity="0.55"
                          VerticalAlignment="Center" />
                <TextBox x:Name="CaptureBox"
                         Grid.Column="1"
                         PlaceholderText="Capture a thought..."
                         AcceptsReturn="False"
                         FontSize="17"
                         BorderThickness="0"
                         Background="Transparent"
                         KeyDown="CaptureBox_KeyDown" />
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Inline #hashtags become tags. Enter to save."
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.5" />
                <TextBlock Grid.Column="1"
                           Text="Esc to cancel"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.5" />
            </Grid>
        </Grid>
    </Border>
</Window>
